# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
/build
next-env.d.ts

# secrets & env — NUNCA subir
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
**/credentials*.json
**/service-account*.json

# vercel
.vercel

# typescript
*.tsbuildinfo

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# os / editor
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# testing / coverage
/coverage

# material de estrategia (confidencial — vive fuera de este repo, guardia extra)
**/estrategia/
**/Fundacion_Estrategica*
**/Conclusiones_*
**/*confidencial*
.claude/
